# Copy to .env and adjust. All values can override config/settings.yaml via APP_* prefix
# See app/config.py for full list of environment variable names.

APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Paths (relative to project root or absolute)
APP_TEMPLATES_DIR=templates
APP_DATA_DIR=data
APP_OUTPUT_DIR=output

# SQLite (replace with postgresql+asyncpg://... when migrating)
APP_DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# LinkedIn automation (optional — use with care; respect site ToS)
APP_LINKEDIN_HEADLESS=true
APP_LINKEDIN_MAX_RETRIES=3

# Browser clients (comma-separated). Include Vite dev origin if using the React UI.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# JWT signing (required for production — use a long random string)
APP_JWT_SECRET=change-me-to-a-long-random-secret

# Groq Cloud (resume tailoring). Get a key at https://console.groq.com/keys
# Also accepted: GROQ_API_KEY
APP_GROQ_API_KEY=gsk_your_api_key_here
APP_GROQ_MODEL=llama-3.3-70b-versatile
